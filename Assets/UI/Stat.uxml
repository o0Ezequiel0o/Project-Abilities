<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement style="flex-grow: 1; background-position-x: center; opacity: 1; margin-right: -1px; margin-bottom: 1.5px; padding-left: 0; padding-right: 0; margin-top: 1.5px; margin-left: 4px; height: auto;">
        <ui:Foldout name="RootFoldout" view-data-key="rootFoldout" style="background-color: rgb(82, 82, 82); border-left-color: rgb(31, 31, 31); border-right-color: rgb(31, 31, 31); border-top-color: rgb(31, 31, 31); border-bottom-color: rgb(31, 31, 31); border-top-width: 0.5px; border-right-width: 0.5px; border-bottom-width: 0.5px; border-left-width: 0.5px; border-top-left-radius: 7px; border-top-right-radius: 7px; border-bottom-right-radius: 7px; border-bottom-left-radius: 7px; transform-origin: center; flex-direction: column; flex-wrap: nowrap; align-items: stretch; justify-content: flex-start; align-self: auto; opacity: 1; display: flex; visibility: visible; overflow: visible; background-size: 100% 100%; margin-right: 0; margin-left: 0; padding-left: 15px; margin-top: 0; margin-bottom: 0; padding-bottom: 0; padding-top: 0; padding-right: 8px; height: auto; color: rgb(231, 231, 231);">
            <ui:FloatField label="Base Value" value="1" name="BaseValue" password="false" binding-path="baseValue" style="padding-right: 0;"/>
            <ui:FloatField label="Increase" value="0" name="Increase" binding-path="increase" style="padding-right: 0;"/>
            <uie:PropertyField binding-path="valueLimits"/>
        </ui:Foldout>
    </ui:VisualElement>
</ui:UXML>
